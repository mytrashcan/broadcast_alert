# ===========================================
#  BCALERT - YouTube Live Discord Alert Bot
# ===========================================

# [필수] Discord 봇 토큰
# Discord Developer Portal (https://discord.com/developers/applications)
# 1. New Application -> Bot 탭 -> Reset Token -> 복사
# 2. Bot 탭 -> MESSAGE CONTENT INTENT 활성화
# 3. OAuth2 -> URL Generator -> bot 체크 -> Send Messages, Embed Links 권한 -> URL로 서버 초대
DISCORD_TOKEN=

# [필수] 알림을 보낼 디스코드 채널 ID (채널 우클릭 -> ID 복사, 개발자모드 필요)
DISCORD_CHANNEL_ID=0

# [필수] 모니터링할 YouTube 채널 URL
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@Parkmis0

# [선택] YouTube 채널 ID (UC로 시작, 없으면 자동으로 가져옴)
YOUTUBE_CHANNEL_ID=

# ── WebSub 설정 (Oracle Cloud 배포 시) ──

# [선택] 웹훅 서버 포트 (설정하면 WebSub 푸시 알림 활성화)
WEBHOOK_PORT=8443

# [선택] 외부에서 접근 가능한 웹훅 URL (Oracle Cloud 공인 IP 사용)
# 예: http://129.xxx.xxx.xxx:8443
WEBHOOK_URL=

# [선택] WebSub HMAC 인증 시크릿
WEBSUB_SECRET=bcalert-secret

# ── 기타 설정 ──

# [선택] 백업 스크래핑 체크 주기 (초, 기본값 300 = 5분, WebSub 실패 시 안전망)
BACKUP_INTERVAL=300

# [선택] 알림 메시지 ({channel_name} = 스트리머 이름)
ALERT_MESSAGE=🔴 **{channel_name}님이 방송을 시작했습니다!**

# [선택] 알림 시 멘션할 역할 ID
ALERT_ROLE_ID=
